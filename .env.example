# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Neo4j connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-please

# Database names (the two graphs live inside one Neo4j instance)
NEO4J_CODEBASE_DB=codebase
NEO4J_MEMORY_DB=agent_memory

# LLM access (used by session-memory entity extraction fallback and embeddings)
OPENAI_API_KEY=sk-replace-me
